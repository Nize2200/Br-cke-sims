<Window x:Class="XInputRemapper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="XInput Remapper" Height="400" Width="700">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="31*"/>
            <ColumnDefinition Width="49*"/>
        </Grid.ColumnDefinitions>
        <TextBlock x:Name="ButtonPressTextBlock" 
                   VerticalAlignment="Top" 
                   FontSize="24" Margin="165,250,0,0" HorizontalAlignment="Left" Width="194" Height="30" Grid.Column="1"/>
        <TextBlock x:Name="JoystickLeft"
                   HorizontalAlignment="Right" 
                   VerticalAlignment="Top" 
                   FontSize="24" Width="164" Margin="0,100,30,0"/>
        <TextBlock x:Name="JoystickRight"
           HorizontalAlignment="Right" 
           VerticalAlignment="Top" 
           FontSize="24" Width="164" Margin="0,185,30,0"/>
        <TextBlock x:Name="TriggerRight"
           HorizontalAlignment="Right" 
           VerticalAlignment="Top" 
           FontSize="24" Width="200" Margin="0,130,70,0" Grid.Column="1"/>
        <TextBlock x:Name="TriggerLeft"
           HorizontalAlignment="Right" 
           VerticalAlignment="Top" 
           FontSize="24" Width="200" Margin="0,185,70,0" Grid.Column="1"/>
        <Button x:Name="RemapFromButton" Content="Button to remap from" HorizontalAlignment="Left" Margin="149,31,0,0" VerticalAlignment="Top" Width="150" Grid.ColumnSpan="2" Click="RemapFromButton_Click"/>
        <TextBlock x:Name="RemapFromTextBlock" 
                   VerticalAlignment="Top" 
                   FontSize="16" Margin="310,31,0,0" HorizontalAlignment="Left" Width="200" Height="30" Grid.ColumnSpan="2"/>
        <Button x:Name="RemapToButton" Content="Button to remap to" HorizontalAlignment="Left" Margin="149,75,0,0" VerticalAlignment="Top" Width="150" Grid.ColumnSpan="2" Click="RemapToButton_Click"/>
        <TextBlock x:Name="RemapToTextBlock" 
                   VerticalAlignment="Top" 
                   FontSize="16" Margin="310,75,0,0" HorizontalAlignment="Left" Width="200" Height="30" Grid.ColumnSpan="2"/>
        <Button x:Name="ApplyRemapButton" Content="Apply Remap" HorizontalAlignment="Left" Margin="149,120,0,0" VerticalAlignment="Top" Width="150" Grid.ColumnSpan="2" Click="ApplyRemapButton_Click"/>
    </Grid>
</Window>
